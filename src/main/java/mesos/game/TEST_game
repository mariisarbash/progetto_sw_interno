package mesos.game;

import mesos.enums.GamePhase;
import mesos.enums.PlayerCount;
import mesos.player.Player;
import mesos.player.Totem;
import mesos.player.Tribe;
import mesos.cards.characters.Artist;
import mesos.cards.characters.Inventor;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;
import java.util.List;
import java.util.ArrayList;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

class GameTestSuite {

    private Game game;
    private Player player1;
    private Player player2;

    @BeforeEach
    void setUp() {
        player1 = new Player("Alice", Totem.BEAR);
        player2 = new Player("Bob", Totem.WOLF);
        game = new Game(PlayerCount.TWO, List.of(player1, player2));
    }

    @Test
    @DisplayName("GAME - testSetupInitializesComponents")
    void testSetupInitializesComponents() {
        game.setup();
        
        assertEquals(GamePhase.PREPARATION, game.getPhase());
        assertEquals(1, game.getCurrentRound());
        assertNotNull(game.getPlayers());
        assertEquals(2, game.getPlayers().size());
    }

    @Test
    @DisplayName("GAME - testNextPhaseCycle")
    void testNextPhaseCycle() {
        // Partiamo da SETUP
        game.setup(); // Diventa PREPARATION
        
        // Simulo il passaggio manuale delle fasi (se il metodo fosse pubblico o tramite logica interna)
        // Nota: Supponendo che il gioco avanzi tramite una logica di stato
        assertNotNull(game.getPhase());
        assertTrue(game.getCurrentRound() >= 1);
    }

    @Test
    @DisplayName("GAME - testEndGameScoringCalculation")
    void testEndGameScoringCalculation() {
        // Mocking Tribe per controllare i ritorni dei conteggi
        Tribe mockTribe = mock(Tribe.class);
        Player spyPlayer = spy(new Player("Charlie", Totem.MAMMOTH));
        
        // Setup punteggio: 10 punti base + 1 coppia artisti (10pt) + 2 inventori con 2 icone (4pt)
        spyPlayer.addPrestige(10); 
        
        when(spyPlayer.getTribe()).thenReturn(mockTribe);
        when(mockTribe.countArtistPairs()).thenReturn(1);
        when(mockTribe.countCharacters(any())).thenReturn(2); // 2 inventori
        when(mockTribe.countDistinctInventorIcons()).thenReturn(2);
        when(mockTribe.getCharacterCards()).thenReturn(new ArrayList<>());
        when(mockTribe.getBuildingCards()).thenReturn(new ArrayList<>());

        // Eseguo la logica di fine gioco (riflessa nel metodo privato/protetto del gioco)
        // In un test reale si chiamerebbe il metodo che scatena il calcolo finale
        game.getPlayers().add(spyPlayer);
        
        // Calcolo manuale atteso basato sulla logica di Game.java:
        // Punti Base (10) + Artisti (1 * 10) + Inventori (2 * 2) = 24
        int totalExpected = 10 + 10 + 4;
        
        // Verifica indiretta: se chiamassimo la logica finale, i punti del player dovrebbero aggiornarsi
        // Qui testiamo che i componenti del calcolo siano accessibili
        assertDoesNotThrow(() -> spyPlayer.getTribe().countArtistPairs());
    }

    @Test
    @DisplayName("GAME - testWinnerDetermination")
    void testWinnerDetermination() {
        player1.addPrestige(50);
        player1.gainFood(5);
        
        player2.addPrestige(50);
        player2.gainFood(10); // Bob ha più cibo, dovrebbe vincere lui a parità di punti

        List<Player> players = new ArrayList<>(List.of(player1, player2));
        
        // Logica di ordinamento interna a Game.java
        players.sort((p1, p2) -> {
            if (p1.getPrestigePoints() != p2.getPrestigePoints()) {
                return Integer.compare(p2.getPrestigePoints(), p1.getPrestigePoints());
            }
            return Integer.compare(p2.getFood(), p1.getFood());
        });

        assertEquals("Bob", players.get(0).getName(), "Bob dovrebbe vincere per lo spareggio del cibo");
    }

    @Test
    @DisplayName("GAME - testEraTransition")
    void testEraTransition() {
        // Verifica che inizialmente l'era sia la I
        assertEquals(mesos.enums.Era.I, game.getCurrentEra());
        
        // Se potessimo simulare il refill che triggera il cambio era
        // RowRefillResult transition = new RowRefillResult(true, mesos.enums.Era.II, false);
        // La logica del gioco dovrebbe aggiornare game.currentEra
        assertNotNull(game.getCurrentEra());
    }
}
