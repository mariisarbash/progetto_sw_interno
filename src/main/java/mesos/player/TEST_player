package mesos.logic;

import mesos.cards.BuildingCard;
import mesos.cards.characters.Hunter;
import mesos.enums.Era;
import mesos.enums.PlayerCount;
import mesos.enums.TotemColor;
import mesos.order.TurnOrderSpace;
import mesos.order.TurnOrderTile;
import mesos.player.Player;
import mesos.player.Totem;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

import java.util.EnumSet;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

class MesosLogicTestSuite {

    private Player player;
    private Totem totem;
    private TurnOrderTile turnOrderTile;

    @BeforeEach
    void setUp() {
        totem = new Totem(TotemColor.RED);
        player = new Player("TestPlayer", totem);
        turnOrderTile = new TurnOrderTile();
    }

    // --- TEST PER IL PACCHETTO ORDER ---

    @Test
    @DisplayName("ORDER - testConfigureForPlayerCount")
    void testConfigureForPlayerCount() {
        turnOrderTile.configureForPlayerCount(PlayerCount.THREE);
        List<TurnOrderSpace> spaces = turnOrderTile.getSpaces();
        
        assertEquals(3, spaces.size());
        assertTrue(spaces.get(2).isLastSpace(), "L'ultimo spazio deve avere il flag lastSpace");
        assertEquals(0, spaces.get(2).getFoodBonus(), "L'ultimo spazio non dovrebbe avere bonus cibo");
    }

    @Test
    @DisplayName("ORDER - testDetermineNewOrder")
    void testDetermineNewOrder() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        Player player2 = new Player("Player2", new Totem(TotemColor.BLUE));
        
        // Player 2 si piazza nello spazio 0, Player 1 (this.player) nello spazio 1
        turnOrderTile.addTotem(player2.getTotem(), player2);
        turnOrderTile.addTotem(player.getTotem(), player);
        
        List<Player> newOrder = turnOrderTile.determineNewOrder();
        
        assertEquals(player2, newOrder.get(0));
        assertEquals(player, newOrder.get(1));
    }

    @Test
    @DisplayName("ORDER - testApplySpaceEffectBonusAndPenalty")
    void testApplySpaceEffectBonusAndPenalty() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        TurnOrderSpace lastSpace = turnOrderTile.getSpaces().get(1); // Ultimo spazio
        
        // Setup: il giocatore non ha cibo
        player.gainFood(0); 
        turnOrderTile.applySpaceEffect(lastSpace, player);
        
        // Dovrebbe aver perso 2 punti prestigio perché non ha potuto pagare 1 cibo
        assertTrue(player.getPrestigePoints() < 0 || player.getPrestigePoints() == -2);
    }

    // --- TEST PER IL PACCHETTO PLAYER ---

    @Test
    @DisplayName("PLAYER - testResourceManagement")
    void testResourceManagement() {
        player.gainFood(5);
        assertTrue(player.payFood(3));
        assertEquals(2, player.getFood());
        
        assertFalse(player.payFood(10), "Non dovrebbe permettere pagamenti superiori alle risorse");
    }

    @Test
    @DisplayName("PLAYER - testAcquireCharacterLogic")
    void testAcquireCharacterLogic() {
        Hunter hunter = new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true);
        player.acquireCharacter(hunter);
        
        assertTrue(player.getTribe().getCharacterCards().contains(hunter));
    }

    @Test
    @DisplayName("PLAYER - testAcquireBuildingWithRealCost")
    void testAcquireBuildingWithRealCost() {
        player.gainFood(10);
        BuildingCard mockBuilding = mock(BuildingCard.class);
        
        // Simuliamo un costo reale di 7 cibo
        when(mockBuilding.calculateRealCost(anyInt())).thenReturn(7);
        
        player.acquireBuilding(mockBuilding);
        
        assertEquals(3, player.getFood(), "Il giocatore dovrebbe aver pagato 7 di cibo");
        assertTrue(player.getTribe().getBuildingCards().contains(mockBuilding));
    }

    @Test
    @DisplayName("PLAYER - testTotemEquality")
    void testTotemEquality() {
        Totem redTotem1 = new Totem(TotemColor.RED);
        Totem redTotem2 = new Totem(TotemColor.RED);
        Totem blueTotem = new Totem(TotemColor.BLUE);

        assertEquals(redTotem1, redTotem2);
        assertNotEquals(redTotem1, blueTotem);
        assertEquals(redTotem1.hashCode(), redTotem2.hashCode());
    }
}
