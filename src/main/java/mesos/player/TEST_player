package mesos.order;

import mesos.enums.PlayerCount;
import mesos.player.Player;
import mesos.player.Totem;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

class TurnOrderTestSuite {

    private TurnOrderTile turnOrderTile;
    private Player mockPlayer1;
    private Player mockPlayer2;

    @BeforeEach
    void setUp() {
        turnOrderTile = new TurnOrderTile();
        mockPlayer1 = mock(Player.class);
        mockPlayer2 = mock(Player.class);
        
        when(mockPlayer1.getTotem()).thenReturn(Totem.BEAR);
        when(mockPlayer2.getTotem()).thenReturn(Totem.WOLF);
    }

    // --- TEST PER TURNORDERTILE ---

    @Test
    @DisplayName("TURN_ORDER_TILE - testConfigureForPlayerCount")
    void testConfigureForPlayerCount() {
        turnOrderTile.configureForPlayerCount(PlayerCount.THREE);
        List<TurnOrderSpace> spaces = turnOrderTile.getSpaces();
        
        assertEquals(3, spaces.size(), "Dovrebbero esserci 3 spazi per 3 giocatori");
        assertTrue(spaces.get(2).isLastSpace(), "L'ultimo spazio dovrebbe avere il flag lastSpace a true");
        assertFalse(spaces.get(0).isLastSpace());
    }

    @Test
    @DisplayName("TURN_ORDER_TILE - testAddTotemAndFirstFreeSpace")
    void testAddTotemAndFirstFreeSpace() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        
        // Primo piazzamento
        TurnOrderSpace space1 = turnOrderTile.addTotem(Totem.BEAR, mockPlayer1);
        assertEquals(0, space1.getPosition());
        assertEquals(Totem.BEAR, space1.getOccupiedBy());
        
        // Verifica che il prossimo spazio libero sia il secondo (indice 1)
        TurnOrderSpace nextFree = turnOrderTile.getFirstFreeSpace();
        assertEquals(1, nextFree.getPosition());
    }

    @Test
    @DisplayName("TURN_ORDER_TILE - testDetermineNewOrder")
    void testDetermineNewOrder() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        
        // Bob (Wolf) si piazza per primo, Alice (Bear) per seconda
        turnOrderTile.addTotem(Totem.WOLF, mockPlayer2);
        turnOrderTile.addTotem(Totem.BEAR, mockPlayer1);
        
        List<Player> newOrder = turnOrderTile.determineNewOrder();
        
        assertEquals(2, newOrder.size());
        assertEquals(mockPlayer2, newOrder.get(0), "Il giocatore nello spazio 0 deve essere il primo nel nuovo ordine");
        assertEquals(mockPlayer1, newOrder.get(1));
    }

    @Test
    @DisplayName("TURN_ORDER_TILE - testApplySpaceEffectBonus")
    void testApplySpaceEffectBonus() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        TurnOrderSpace space = turnOrderTile.getSpaces().get(0); // Spazio 0 ha solitamente bonus 1
        
        turnOrderTile.applySpaceEffect(space, mockPlayer1);
        
        verify(mockPlayer1, times(1)).gainFood(space.getFoodBonus());
    }

    @Test
    @DisplayName("TURN_ORDER_TILE - testApplySpaceEffectPenalty")
    void testApplySpaceEffectPenalty() {
        turnOrderTile.configureForPlayerCount(PlayerCount.TWO);
        // L'ultimo spazio (indice 1)
        TurnOrderSpace lastSpace = turnOrderTile.getSpaces().get(1);
        
        // Simuliamo che il giocatore non possa pagare il cibo
        when(mockPlayer1.payFood(1)).thenReturn(false);
        
        turnOrderTile.applySpaceEffect(lastSpace, mockPlayer1);
        
        verify(mockPlayer1).removePrestige(2);
    }

    // --- TEST PER TURNORDERSPACE ---

    @Test
    @DisplayName("TURN_ORDER_SPACE - testSpaceStateManagement")
    void testSpaceStateManagement() {
        TurnOrderSpace space = new TurnOrderSpace(0, 1, false);
        
        assertTrue(space.isFree());
        space.assignTotem(Totem.MAMMOTH);
        assertFalse(space.isFree());
        assertEquals(Totem.MAMMOTH, space.getOccupiedBy());
        
        space.clear();
        assertTrue(space.isFree());
        assertNull(space.getOccupiedBy());
    }
}
