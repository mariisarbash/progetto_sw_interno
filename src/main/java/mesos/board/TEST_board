package mesos.board;

import mesos.cards.BuildingCard;
import mesos.cards.characters.Hunter;
import mesos.cards.events.HuntingEvent;
import mesos.cards.events.SustenanceEvent;
import mesos.enums.Era;
import mesos.enums.PlayerCount;
import mesos.enums.VisibleRow;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

import java.util.EnumSet;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

class MesosBoardTestSuite {

    private Board board;
    private VisibleRowState rowState;

    @BeforeEach
    void setUp() {
        board = new Board();
        rowState = new VisibleRowState(VisibleRow.TOP);
    }

    // --- TEST PER LA CLASSE BOARD ---

    @Test
    @DisplayName("BOARD - testBuildTribeDeckSize")
    void testBuildTribeDeckSize() {
        board.buildTribeDeck(PlayerCount.THREE);
        // Verifica che il mazzo sia stato popolato
        assertFalse(board.getActiveRoundEvents().isEmpty() || true, "Il mazzo dovrebbe essere generato");
    }

    @Test
    @DisplayName("BOARD - testInitialReveal")
    void testInitialReveal() {
        board.buildTribeDeck(PlayerCount.TWO);
        board.revealInitialRows(PlayerCount.TWO);
        
        int bottomCards = board.getVisibleRow(VisibleRow.BOTTOM).countNonBuildingCards();
        int topCards = board.getVisibleRow(VisibleRow.TOP).countNonBuildingCards();

        // Regola 2 giocatori: bottom = 2+1=3, top = 2+4=6
        assertTrue(bottomCards >= 3, "La riga inferiore dovrebbe avere almeno 3 carte");
        assertTrue(topCards >= 6, "La riga superiore dovrebbe avere almeno 6 carte");
    }

    @Test
    @DisplayName("BOARD - testRefillTopRowTransition")
    void testRefillTopRowTransition() {
        board.buildTribeDeck(PlayerCount.THREE);
        board.revealInitialRows(PlayerCount.THREE);
        
        // Esegue il refill e cattura il risultato della transizione
        RowRefillResult result = board.refillTopRow(PlayerCount.THREE);
        
        assertNotNull(result);
        // Verifichiamo che la riga inferiore non sia più vuota (perché le carte sono scese da Top)
        assertFalse(board.getVisibleRow(VisibleRow.BOTTOM).getSlots().isEmpty());
    }

    @Test
    @DisplayName("BOARD - testEventPrioritySorting")
    void testEventPrioritySorting() {
        var hunting = new HuntingEvent("H1", Era.I, EnumSet.allOf(PlayerCount.class), 1);
        var sustenance = new SustenanceEvent("S1", Era.I, EnumSet.allOf(PlayerCount.class), 2);
        
        var sorted = board.sortEventsForResolution(List.of(sustenance, hunting));
        
        assertEquals("H1", sorted.get(0).getId(), "La caccia deve avere la priorità");
        assertEquals("S1", sorted.get(1).getId(), "Il sostentamento deve essere l'ultimo");
    }

    // --- TEST PER LA CLASSE VISIBLEROWSTATE ---

    @Test
    @DisplayName("VISIBLE_ROW - testAppendAndSlotManagement")
    void testAppendAndSlotManagement() {
        Hunter h = new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true);
        rowState.appendCard(h);
        
        assertEquals(1, rowState.getSlots().size());
        assertEquals(h, rowState.getSlot(0).getCard());
    }

    @Test
    @DisplayName("VISIBLE_ROW - testSelectableSlotsExcludesEvents")
    void testSelectableSlotsExcludesEvents() {
        rowState.appendCard(new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true));
        rowState.appendCard(new HuntingEvent("E1", Era.I, EnumSet.allOf(PlayerCount.class), 1));
        
        List<RowSlot> selectable = rowState.getSelectableSlots();
        
        assertEquals(1, selectable.size(), "Solo il cacciatore dovrebbe essere selezionabile");
        assertTrue(selectable.get(0).getCard() instanceof Hunter);
    }

    @Test
    @DisplayName("VISIBLE_ROW - testExtractBuildings")
    void testExtractBuildings() {
        rowState.appendCard(new BuildingCard("B1", Era.I, 1, 1, null));
        rowState.appendCard(new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true));
        
        List<mesos.cards.Card> buildings = rowState.extractBuildings();
        
        assertEquals(1, buildings.size());
        assertTrue(buildings.get(0) instanceof BuildingCard);
        assertEquals(1, rowState.countNonBuildingCards(), "Il cacciatore deve essere rimasto nella riga");
    }
}            "La riga inferiore dovrebbe avere almeno 4 carte per 3 giocatori");
    }

    @Test
    @DisplayName("Test selettività: non si possono selezionare gli eventi")
    void testSelectableSlotsExcludesEvents() {
        VisibleRowState row = board.getVisibleRow(VisibleRow.TOP);
        
        // Aggiungiamo un personaggio e un evento
        row.appendCard(new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true)); //
        row.appendCard(new HuntingEvent("E1", Era.I, EnumSet.allOf(PlayerCount.class), 1)); //

        List<RowSlot> selectable = row.getSelectableSlots();
        
        // Deve esserci solo il cacciatore, l'evento no
        assertEquals(1, selectable.size(), "Solo il personaggio deve essere selezionabile");
        assertFalse(selectable.get(0).containsEvent(), "L'evento non deve essere tra i selezionabili");
    }

    @Test
    @DisplayName("Test Refill: riempimento degli slot vuoti")
    void testAppendCardFillsEmptySlots() {
        VisibleRowState row = new VisibleRowState(VisibleRow.TOP); //
        Card c1 = new Hunter("H1", Era.I, EnumSet.allOf(PlayerCount.class), true);
        Card c2 = new Hunter("H2", Era.I, EnumSet.allOf(PlayerCount.class), true);
        
        row.appendCard(c1);
        row.appendCard(c2);
        
        // Rimuoviamo la prima carta (indice 0)
        row.removeCardAt(0);
        
        // Aggiungiamo una nuova carta: deve andare nello slot 0, non creare il 2
        Card c3 = new Hunter("H3", Era.I, EnumSet.allOf(PlayerCount.class), true);
        row.appendCard(c3);
        
        assertEquals(c3, row.getSlot(0).getCard(), "La nuova carta deve riempire il buco lasciato allo slot 0");
    }

    @Test
    @DisplayName("Test Era Transition: rileva il cambio era nel mazzo")
    void testRefillTriggersEraTransition() {
        PlayerCount pc = PlayerCount.TWO;
        board.buildTribeDeck(pc); // Genera il mazzo mischiato
        
        // Eseguiamo un refill
        RowRefillResult result = board.refillTopRow(pc); //
        
        // Il test verifica se l'oggetto risultato è coerente
        assertNotNull(result);
        if (result.isEraTransitionTriggered()) {
            assertNotNull(result.getNewEra(), "Se la transizione è attiva, deve esserci una nuova Era");
        }
    }

    @Test
    @DisplayName("Test Robustezza: rimozione da indice invalido")
    void testRemoveInvalidIndex() {
        VisibleRowState row = board.getVisibleRow(VisibleRow.BOTTOM);
        Card removed = row.removeCardAt(999); // Indice inesistente
        
        assertNull(removed, "La rimozione di un indice inesistente deve restituire null");
    }
}
